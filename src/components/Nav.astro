---
const CALENDLY = "https://calendly.com/servicefranceconseilformation/30min?month=2026-04";
---

<header class="nav-wrapper">
  <nav class="container nav">
    <a href="#hero" class="nav-logo" aria-label="France Conseil & Formations — Accueil">
      <img
        src="/logo-fcf.png"
        alt="France Conseil & Formations"
        class="nav-logo-img"
        width="140"
        height="48"
      />
    </a>

    <a
      href={CALENDLY}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-cta nav-cta"
      onclick="fbq && fbq('track', 'Lead')"
    >
      Réserver mon appel gratuit
    </a>
  </nav>
</header>

<style>
  .nav-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(248, 250, 252, 0.94);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(0, 85, 164, 0.12);
    box-shadow: 0 1px 16px rgba(0, 85, 164, 0.07);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.85rem;
    gap: 1rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav-logo-img {
    height: clamp(32px, 5vw, 44px);
    width: auto;
    object-fit: contain;
    display: block;
  }

  .nav-cta {
    font-size: clamp(0.75rem, 1.8vw, 0.95rem);
    padding: 0.7em 1.6em;
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .nav-cta {
      padding: 0.6em 1.1em;
    }
  }
</style>
