---
const CALENDLY = "https://calendly.com/servicefranceconseilformation/30min?month=2026-04";
const isVmdtr = Astro.url.pathname.startsWith("/vmdtr");
const otherLabel = isVmdtr ? "FORMATION TAXI & VTC" : "FORMATION VMDTR";
const otherHref  = isVmdtr ? "/" : "/vmdtr";
---

<header class="nav-wrapper">
  <nav class="container nav">
    <a href="#hero" class="nav-logo" aria-label="France Conseil & Formations — Accueil">
      <img
        src="/logo-fcf.png"
        alt="France Conseil & Formations"
        class="nav-logo-img"
        width="140"
        height="48"
      />
    </a>

    <div class="nav-actions">
      <a href={otherHref} class="nav-vmdtr-btn">
        {otherLabel}
      </a>
      <a
        href={CALENDLY}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-cta nav-cta"
        onclick="fbq && fbq('track', 'Lead')"
      >
        Réserver mon appel gratuit
      </a>
    </div>
  </nav>
</header>

<style>
  .nav-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(248, 250, 252, 0.94);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(0, 85, 164, 0.12);
    box-shadow: 0 1px 16px rgba(0, 85, 164, 0.07);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.85rem;
    gap: 1rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav-logo-img {
    height: clamp(32px, 5vw, 44px);
    width: auto;
    object-fit: contain;
    display: block;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .nav-vmdtr-btn {
    font-family: var(--font-title);
    font-weight: 700;
    font-size: clamp(0.7rem, 1.6vw, 0.85rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    background: var(--blue);
    border-radius: 4px;
    padding: 0.55em 1.1em;
    white-space: nowrap;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .nav-vmdtr-btn:hover {
    background: #0066c8;
    transform: translateY(-1px);
  }

  .nav-cta {
    font-size: clamp(0.75rem, 1.8vw, 0.95rem);
    padding: 0.7em 1.6em;
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .nav-vmdtr-btn {
      padding: 0.5em 0.8em;
      font-size: 0.68rem;
    }
    .nav-cta {
      padding: 0.6em 1em;
    }
  }
</style>
